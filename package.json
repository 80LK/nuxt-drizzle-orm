{
  "name": "nuxt-drizzle-orm",
  "version": "1.0.0",
  "description": "My new Nuxt module",
  "repository": "your-org/my-module",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ndo": "./bin/ndo.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "lint": "eslint .",
    "db:generate": "ndo generate --cwd playground",
    "db:migrate": "ndo migrate --cwd playground"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "pathe": "^2.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "changelogen": "^0.6.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "nuxt": "^4.4.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
